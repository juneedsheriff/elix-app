# Copy to .env.server.local for backend scripts only (never commit, never expose to Vite).
# These values must NOT use the VITE_ prefix.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Supabase Management API — required for npm run db:apply-auth-smtp
# SUPABASE_ACCESS_TOKEN=sbp_...

# Resend custom SMTP for patient signup verification emails (npm run db:apply-auth-smtp)
# RESEND_API_KEY=re_...
# SMTP_ADMIN_EMAIL=noreply@yourdomain.com
# SMTP_SENDER_NAME=Elix Health
# SMTP_PORT=465
# SITE_URL=http://localhost:3000
# URI_ALLOW_LIST=http://localhost:3000/**,https://your-app.vercel.app/**

POSTGRES_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_PRISMA_URL=postgres://...
