# Vite exposes only variables prefixed with VITE_ to the browser.
# Use the anon (public) key here — never put service role or database passwords in the client.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Worker URL for medical record uploads (R2). Deploy workers/medical-records first.
# VITE_R2_API_URL=https://elix-medical-records.elix-juneed.workers.dev

# Admin login enable/disable + password (deploy workers/admin-auth first).
# Local: npm run worker:admin-auth:dev → http://127.0.0.1:8788 (see workers/admin-auth/.dev.vars.example)
# Production: VITE_ADMIN_AUTH_API_URL=https://elix-admin-auth.elix-juneed.workers.dev
# VITE_ADMIN_AUTH_API_URL=http://127.0.0.1:8788

# Optional: fixed redirect base for email confirm / password reset (must match Supabase Redirect URLs).
# Dev (Vite): http://localhost:3000
# Production: https://your-app.vercel.app
# VITE_APP_URL=http://localhost:3000

# Server-only (do NOT prefix with VITE_ — not used by this React app):
# Required for npm run db:migrate-records-to-r2 and other db:* scripts:
# SUPABASE_SERVICE_ROLE_KEY=
# For npm run db:apply-elix-id (database password from Dashboard → Settings → Database):
# SUPABASE_DB_PASSWORD=
# Or: POSTGRES_URL_NON_POOLING=postgresql://postgres.[ref]:[PASSWORD]@...supabase.com:5432/postgres
# Or: SUPABASE_ACCESS_TOKEN=sbp_... (https://supabase.com/dashboard/account/tokens)
# For npm run db:apply-auth-smtp (Resend custom SMTP + OTP email template):
# RESEND_API_KEY=re_...
# SMTP_ADMIN_EMAIL=noreply@yourdomain.com
# MAILER_OTP_LENGTH=6
# POSTGRES_URL=
# DOCTOR_DEFAULT_PASSWORD=Elix@123
# PATIENT_DEFAULT_PASSWORD=Elix@123
